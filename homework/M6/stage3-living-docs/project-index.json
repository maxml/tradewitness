{
  "name": "tradewitness-mono",
  "type": "fullstack-monorepo",
  "description": "TradeWitness — trading journal & analytics SaaS. pnpm + Turborepo monorepo. Next.js app + marketing landing, Drizzle/Supabase Postgres, Clerk auth, Stripe billing, Cloudflare R2 storage, plus M3-M5 AI additions: feature-flags MCP, docs-search MCP, RAG (Qdrant) and an n8n auto-pilot layer.",
  "tech_stack": {
    "app": "Next.js (App Router) + React + TypeScript (strict) + TailwindCSS v3 + Redux Toolkit",
    "landing": "Next.js + TypeScript (no Tailwind — v4 avoided per CLAUDE.md)",
    "database": "Supabase Postgres via Drizzle ORM (RLS disabled — app-layer authz; see ADR-0001)",
    "auth": "Clerk (sessions/JWT) + svix-verified webhooks",
    "billing": "Stripe (checkout + signed webhooks)",
    "storage": "Cloudflare R2 via aws4fetch (ADR-0002)",
    "ai_additions": [
      "feature-flags MCP (stdio + HTTP wrapper) — Node/TS",
      "search-docs MCP (vector search over docs/m3-corpus) — Node/TS",
      "RAG ingest/query over Qdrant — Node/TS",
      "n8n auto-pilot workflows (M5)"
    ],
    "build": "Turborepo (ADR-0003) + pnpm workspaces"
  },
  "subprojects": {
    "app": {
      "path": "apps/app/",
      "description": "Main authenticated product: trade journal, statistics, strategies, AI report (OCR/Claude), feature dashboard.",
      "tech": "Next.js App Router + Drizzle + Clerk + Stripe + R2",
      "key_paths": {
        "server_actions": "apps/app/src/server/actions/",
        "api_routes": "apps/app/src/app/api/",
        "db": "apps/app/src/drizzle/",
        "lib": "apps/app/src/lib/",
        "components": "apps/app/src/components/",
        "features": "apps/app/src/features/",
        "zod_schemas": "apps/app/src/zodSchema/"
      }
    },
    "landing": {
      "path": "apps/landing/",
      "description": "Public marketing site. TailwindCSS v4 intentionally avoided (CLAUDE.md rule).",
      "tech": "Next.js + TypeScript"
    },
    "feature_flags_mcp": {
      "path": "mcps/feature-flags/",
      "description": "Feature-flags MCP server: stdio (index.ts) + HTTP wrapper for n8n (http.ts). Reads/writes data/feature-flags/features.json via the Next route; validates with DependencyGraph from feature-flags-core.",
      "entry": "mcps/feature-flags/src/index.ts",
      "tech": "Node/TS + @modelcontextprotocol/sdk + zod",
      "spec": "docs/specs/feature-flags-mcp-spec.md"
    },
    "search_docs_mcp": {
      "path": "mcps/search-docs/",
      "description": "Docs-search MCP: vector search over docs/m3-corpus (ADRs, incidents, runbooks, features). Used by the search_project_docs tool.",
      "entry": "mcps/search-docs/src/index.ts",
      "tech": "Node/TS + embeddings + Qdrant"
    },
    "rag": {
      "path": "mcps/rag/",
      "description": "RAG pipeline: ingest.ts chunks+embeds the corpus and upserts to Qdrant; query.ts embeds a query and searches.",
      "entry": "mcps/rag/query.ts",
      "tech": "Node/TS + @xenova/transformers + langchain + Qdrant",
      "spec": "docs/specs/rag-spec.md"
    },
    "feature_flags_core": {
      "path": "packages/feature-flags-core/",
      "description": "Shared core: DependencyGraph + state-change validation. Canonical invariant for feature-flag dependencies.",
      "tech": "TypeScript library"
    },
    "api_types": {
      "path": "packages/api-types/",
      "description": "Declared shared wire-format types. NOTE: currently an orphan (imported by zero .ts files) — see architecture-review.md.",
      "tech": "TypeScript types"
    }
  },
  "system_folders": {
    ".claude/": "Claude Code config: agents/, scripts/, settings.local.json",
    ".claude/agents/": "Sub-agent definitions (security/performance/architecture/legacy-auditor/test-writer mates)",
    ".claude/scripts/": "Maintenance scripts incl. update_project_index.py",
    ".codex/": "Codex agent rules (mirror of AGENTS.md)",
    "docs/": "Living docs: adr/, architecture, specs/ (M6), and the m3-corpus RAG fixture",
    "docs/adr/": "Real Architecture Decision Records (0001-0003) + proposed 0004-0005 (M6)",
    "docs/m3-corpus/": "Synthetic RAG corpus ingested by search-docs MCP — fixture DATA, not project prose (do not treat as authoritative docs)",
    "docs/specs/": "M6 reverse-engineered module specs (feature-flags MCP, RAG)",
    "data/feature-flags/": "features.json — system of record for feature flags (NEVER edit directly; use MCP)",
    "homework/": "Course homework submissions (M4, M5, M6)",
    "scripts/": "Repo utility scripts"
  },
  "root_files": {
    "CLAUDE.md": "Claude Code project rules (TS strict, Tailwind policy, drizzle-kit, MCP usage)",
    "AGENTS.md": "Codex/agent rules mirror of CLAUDE.md",
    "GEMINI.md": "Gemini agent rules mirror",
    "DESIGN.md": "M4 design system rules",
    "README.md": "Project overview",
    "FINDINGS.md": "Earlier audit findings",
    "report.md": "Homework session report",
    "docker-compose.yml": "Local infra (Qdrant etc.)",
    "turbo.json": "Turborepo pipeline config",
    "pnpm-workspace.yaml": "pnpm workspace definition",
    ".env.example": "Environment variable template (canonical var list)"
  },
  "hard_rules": [
    "ALWAYS read project-index.json FIRST at session start for repo structure orientation (this file).",
    "Always use TypeScript with strict mode.",
    "Feature flags: NEVER edit data/feature-flags/features.json directly — use the feature-flags MCP tools (get_feature_info, set_feature_state, ...).",
    "Docs questions: use the search_project_docs (search-docs MCP) tool first — do not grep docs/ directly unless it fails.",
    "Drizzle ORM: run `drizzle-kit generate` after any schema change.",
    "Avoid TailwindCSS in apps/landing (v4); it is allowed in apps/app (v3).",
    "Authorization has NO database backstop (RLS disabled, ADR-0001): every user-owned read/write MUST carry auth() + eq(userId); derive userId from the session, never from a caller-supplied argument (see proposed ADR-0004).",
    "Use Conventional Commits (feat:, fix:, docs:, chore:, refactor:; scope optional).",
    "Never commit real secrets; .env.example is the canonical variable list.",
    "Design changes must follow DESIGN.md."
  ],
  "ai_routing": {
    "feature_flag_queries": "feature-flags MCP get_feature_info (not direct features.json reads)",
    "feature_flag_changes": "feature-flags MCP set_feature_state / dependency-aware tools",
    "docs_search": "search-docs MCP search_project_docs (not grep + read of docs/)",
    "structure_questions": "this project-index.json (do not walk the filesystem tree)",
    "module_behavior": "docs/specs/*-spec.md (reverse-engineered specs for MCP + RAG)",
    "architecture_decisions": "docs/adr/ (0001-0003 real; 0004-0005 proposed in M6)"
  },
