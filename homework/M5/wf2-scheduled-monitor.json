        "url": "http://host.docker.internal:7733/tools/get_feature_info",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"feature_id\": \"{{ $fromAI('feature_id', 'exact feature_id like search_v2', 'string') }}\"\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequestTool",
      "typeVersion": 4.4,
      "position": [
        1660,
        460
      ],
      "id": "auto-wf2-get_feature_info",
      "name": "get_feature_info",
      "credentials": {
        "httpHeaderAuth": {
          "id": "r7KAB9qrrxTAXvcA",
          "name": "m3-wrapper-bearer"
        }
      }
    },
    {
      "parameters": {
        "toolDescription": "Change feature flag status. Only call when current status does NOT already match the target. Inputs: feature_id (string), state (Enabled | Disabled | Testing).",
        "method": "POST",
        "url": "http://host.docker.internal:7733/tools/set_feature_state",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"feature_id\": \"{{ $fromAI('feature_id', 'exact feature_id like search_v2', 'string') }}\",\n  \"state\": \"{{ $fromAI('state', 'one of Enabled, Disabled, Testing', 'string') }}\"\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequestTool",
      "typeVersion": 4.4,
      "position": [
        1840,
        460
      ],
      "id": "auto-wf2-set_feature_state",
      "name": "set_feature_state",
      "credentials": {
        "httpHeaderAuth": {
          "id": "r7KAB9qrrxTAXvcA",
          "name": "m3-wrapper-bearer"
        }
      }
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "p1",
              "name": "raw",
              "type": "string",
              "value": "={{ String($json.output ?? '') }}"
            },
            {
              "id": "p2",
              "name": "clean",
              "type": "string",
              "value": "={{ (() => { const r = String($json.output ?? ''); const i = r.indexOf('{'); const j = r.lastIndexOf('}'); return (i>=0 && j>i) ? r.slice(i,j+1) : r; })() }}"
            },
            {
              "id": "p3",
              "name": "parsed",
              "type": "object",
              "value": "={{ (() => { const r = String($json.output ?? ''); const i = r.indexOf('{'); const j = r.lastIndexOf('}'); if (i<0||j<=i) return {}; try { return JSON.parse(r.slice(i,j+1)); } catch { return {}; } })() }}"
            },
            {
              "id": "p4",
              "name": "alert_message",
              "type": "string",
              "value": "={{ (() => { const r = String($json.output ?? ''); const i = r.indexOf('{'); const j = r.lastIndexOf('}'); if (i<0||j<=i) return String($json.output ?? ''); try { return JSON.parse(r.slice(i,j+1)).alert_message || ''; } catch { return ''; } })() }}"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        1860,
        230
      ],
