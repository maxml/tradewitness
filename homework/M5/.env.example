# Copy to .env.local and fill in real values. .env.local is gitignored.
# Never commit secret values.

# Telegram bot token from @BotFather. Format: 1234567:ABC-DEF...
TELEGRAM_BOT_TOKEN=

# Chat ID for alerts. Find via:
#   curl "https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/getUpdates"
# after sending /start to your bot. See docs/01-setup.md §1.2.
TELEGRAM_CHAT_ID=

# Random secret for X-API-Key header on the n8n webhook.
# Generate with:  openssl rand -hex 32
N8N_WEBHOOK_API_KEY=

# Bearer token used by n8n to reach the local M3 MCP.
M3_MCP_API_KEY=
