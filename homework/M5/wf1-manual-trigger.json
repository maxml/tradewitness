        }
      }
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict",
                  "version": 2
                },
                "combinator": "and",
                "conditions": [
                  {
                    "id": "a1",
                    "leftValue": "={{ $json.body.feature_id }}",
                    "rightValue": "",
                    "operator": {
                      "type": "string",
                      "operation": "empty"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "missing_feature_id"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict",
                  "version": 2
                },
                "combinator": "and",
                "conditions": [
                  {
                    "id": "a2",
                    "leftValue": "={{ $json.body.action }}",
                    "rightValue": "",
                    "operator": {
                      "type": "string",
                      "operation": "empty"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "missing_action"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict",
                  "version": 2
                },
                "combinator": "and",
                "conditions": [
                  {
                    "id": "a3",
                    "leftValue": "={{ ['check','test','rollback','rollout'].includes($json.body.action) }}",
                    "rightValue": false,
                    "operator": {
                      "type": "boolean",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "invalid_action"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict",
                  "version": 2
                },
                "combinator": "and",
                "conditions": [
                  {
                    "id": "a4",
                    "leftValue": "={{ $json.body.traffic_percentage !== undefined && ($json.body.traffic_percentage < 0 || $json.body.traffic_percentage > 100) }}",
                    "rightValue": true,
                    "operator": {
                      "type": "boolean",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "invalid_traffic"
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra"
        }
      },
      "id": "05f4f18a-7793-475d-aa80-6f826dcdd5b1",
      "name": "Switch",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [
        -288,
        192
      ]
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "={{ JSON.stringify({success:false, message:\"Validation error: \" + ($json.outputKey || \"invalid_request\"), rejected_at:\"input-validation\"}) }}",
        "options": {
          "responseCode": 400,
          "responseHeaders": {
            "entries": [
              {
                "name": "Content-Type",
                "value": "application/json; charset=utf-8"
              }
            ]
          }
        }
      },
      "id": "74ba5a64-0575-4239-b778-5789e1758d93",
      "name": "Respond 400",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ JSON.stringify($json.body) }}",
        "options": {
          "systemMessage": "=Goal:\nExecute the operator request for feature flag {{ $json.body.feature_id }}.\n\nAvailable tools (you MUST use them; never fabricate):\n- get_feature_info(feature_id) \u2014 reads current state\n- set_feature_state(feature_id, state) \u2014 mutates status\n- adjust_traffic_rollout(feature_id, traffic_percentage) \u2014 mutates traffic\n\nEXECUTION RULES (mandatory, no exceptions):\n1. Your FIRST action MUST be a tool call to get_feature_info.\n2. If the action requires mutation, you MUST then call the appropriate mutation tool.\n3. After the mutation, you MUST call get_feature_info AGAIN to confirm.\n4. The \"current_state\" field in your final JSON MUST be the literal object returned by the LAST get_feature_info call, copied field-for-field. Do not invent shape or values.\n5. If you skip any required tool call, your output is INVALID.\n\nOperator command (from webhook body):\n- action = {{ $json.body.action }}\n- target_state = {{ $json.body.target_state }}\n- traffic_percentage = {{ $json.body.traffic_percentage }}\n\nAction flow:\n- \"check\"    \u2192 get_feature_info \u2192 return.\n- \"test\"     \u2192 get_feature_info \u2192 if status==Testing return no_op success=true \u2192 else set_feature_state(Testing) \u2192 get_feature_info.\n- \"rollback\" \u2192 get_feature_info \u2192 if status==Disabled return no_op success=true \u2192 else set_feature_state(Disabled) \u2192 get_feature_info.\n- \"rollout\"  \u2192 get_feature_info \u2192 adjust_traffic_rollout(traffic_percentage) \u2192 get_feature_info.\n\nOutput (strict JSON):\n{\n  \"success\": boolean,\n  \"message\": string,\n  \"current_state\": <object from the FINAL get_feature_info, with fields: name, status, traffic_percentage, depends_on, last_modified> | null,\n  \"rejected_at\": \"input-validation\" | \"tool-execution\" | null\n}\n\nFORMAT:\n- Return JSON only. First char `{`, last char `}`.\n- DO NOT wrap in markdown code fences.",
          "maxIterations": 6,
          "returnIntermediateSteps": true
        }
      },
      "id": "4b3479e7-973e-4e1c-a098-bf9e16b1490c",
      "name": "AI Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [
        0,
        352
      ]
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "={{ ((s) => { const m = String(s).match(/```(?:json)?\\s*([\\s\\S]*?)```/); return m ? m[1].trim() : (typeof s === 'string' ? s : JSON.stringify(s)); })($json.output ?? $json) }}",
        "options": {
          "responseCode": 200,
          "responseHeaders": {
            "entries": [
              {
                "name": "Content-Type",
                "value": "application/json; charset=utf-8"
              }
            ]
          }
        }
      },
