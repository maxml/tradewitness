# ─── Database (Supabase Postgres) ────────────────────────────────────
# For migrations / dev: direct connection on port 5432
#   Format: postgresql://postgres:<PASSWORD>@db.<PROJECT>.supabase.co:5432/postgres
# For production (Docker/VPS): transaction pooler on port 6543
#   Format: postgresql://postgres.<PROJECT>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres
# NOTE: Drizzle client sets prepare: false to stay compatible with the transaction pooler.
DATABASE_URL=

# ─── Auth (Clerk) ────────────────────────────────────────────────────
# https://dashboard.clerk.com → API keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Webhook endpoint secret. Obtain from Clerk → Webhooks → <endpoint> → Signing secret.
# For local dev: expose /api/webhooks/clerk via ngrok or set CLERK_WEBHOOK_SKIP_VERIFY=true.
CLERK_WEBHOOK_SECRET=
# Dev-only escape hatch: skips signature verification on the webhook endpoint.
# Leave UNSET in production.
CLERK_WEBHOOK_SKIP_VERIFY=

# ─── AI (Anthropic / Claude) ─────────────────────────────────────────
# Used by /private/tradeAI and /api/claude routes.
# Slated for removal in Task 3 (BYOAI copy-prompt flow).
# Leave empty to intentionally break AI endpoints until Task 3.
CLAUDE_API_KEY=

# ─── Object Storage (Cloudflare R2) ──────────────────────────────────
# From Cloudflare dashboard → R2 → Overview (Account ID at top-right)
R2_ACCOUNT_ID=
# From R2 → Manage R2 API Tokens → create token with Object Read & Write
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# The bucket you created, e.g. tradewitness-screenshots
R2_BUCKET_NAME=
# Public base URL — either https://pub-<hash>.r2.dev (enable in bucket settings)
# or a custom domain like https://cdn.tradewitness.com
R2_PUBLIC_URL=

# ─── Payments (Stripe) — optional ────────────────────────────────────
# Names below match the actual process.env references in the code.
STRIPE_SECRET_API_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_PUBLISHABLE_STRIPE_API_KEY=

# ─── URLs (cross-app navigation + server self-reference) ─────────────
# NEXT_PUBLIC_SERVER_URL: this app's own URL (used for webhooks, absolute links, OG tags)
NEXT_PUBLIC_SERVER_URL=http://localhost:3001
# NEXT_PUBLIC_LANDING_URL: landing site URL (used for "Back to home" link)
NEXT_PUBLIC_LANDING_URL=http://localhost:3000

# --- FEATURE FLAGS & ADMIN ---
FEATURE_FLAGS_FILE=../../data/feature-flags/features.json
FEATURE_FLAGS_API_KEY=local-m3-change-me
APP_INTERNAL_URL=http://127.0.0.1:3001
ADMIN_EMAILS=you@example.com
