# ---------------------------------------------------------
# ROOT .env.example
# Copy these values into apps/app/.env.local and apps/landing/.env.local
# ---------------------------------------------------------

# --- SHARED ROUTING ---
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_LANDING_URL=http://localhost:3000
APP_INTERNAL_URL=http://127.0.0.1:3001

# --- SUPABASE (DATABASE) ---
# Direct connection for Drizzle (apps/app)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
# Supabase Client connection (apps/landing)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsIn...

# --- CLERK (AUTHENTICATION) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY
CLERK_SECRET_KEY=sk_test_YOUR_KEY

# --- CLOUDFLARE R2 (OBJECT STORAGE) ---
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=trade-witness-bucket
R2_PUBLIC_URL=https://pub-xxxxxx.r2.dev

# --- FEATURE FLAGS & AI ---
STRIPE_ENABLED=false
FEATURE_FLAGS_FILE=data/feature-flags/features.json
FEATURE_FLAGS_API_KEY=local-m3-change-me
ADMIN_EMAILS=you@example.com
CLAUDE_API_KEY=sk-ant-api03-...

# --- M3 RAG / MCP ---
# Required only if the selected embedding/vector stack needs them.
EMBEDDING_PROVIDER=bge-m3
EMBEDDING_MODEL=BAAI/bge-m3
OPENAI_API_KEY=sk-...
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=tradewitness_bge_m3
